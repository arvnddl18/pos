{
  "name": "pos-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply pos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pos-db --remote"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.94.0"
  }
}
